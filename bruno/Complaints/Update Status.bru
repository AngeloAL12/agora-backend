meta {
  name: Update Status
  type: http
  seq: 6
}

post {
  url: {{base_url}}/complaints/{{complaint_id}}/status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

body:json {
  {
    "status": "..."
  }
}

vars:pre-request {
  complaint_id: 1
}

settings {
  encodeUrl: true
  timeout: 0
}
