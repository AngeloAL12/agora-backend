meta {
  name: Get Complaint
  type: http
  seq: 4
}

get {
  url: {{base_url}}/complaints/{{complaint_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

vars:pre-request {
  complaint_id: 2
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Obtener Detalle de Queja
  Obtiene la información detallada de una queja específica, incluyendo sus evidencias y el estado actual.
  
  ## Parámetros de Ruta
  - `complaint_id`: ID único de la queja.
}
