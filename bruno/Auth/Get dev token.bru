meta {
  name: Get dev token
  type: http
  seq: 4
}

get {
  url: {{base_url}}/auth/dev-token?testing_secret=pruebas&user_id=1
  body: none
  auth: bearer
}

params:query {
  testing_secret: pruebas
  user_id: 1
}

auth:bearer {
  token: {{auth_token}}
}

script:post-response {
  if (res.getStatus() === 200) {
    const body = res.getBody();
    bru.setEnvVar("auth_token", body.access_token);
    console.log("Token guardado exitosamente: ", body.access_token);
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Obtener Token de Desarrollo
  Genera un token de acceso para pruebas locales utilizando un secreto de prueba y un ID de usuario.
  
  ## Parámetros Query
  - `testing_secret`: Secreto configurado para desarrollo.
  - `user_id`: ID del usuario para el cual se generará el token.
}
