meta {
  name: Logout
  type: http
  seq: 6
}

post {
  url: {{base_url}}/auth/logout
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Logout
  Revoca la sesion activa eliminando el `refresh_token` guardado para el usuario autenticado.
}
