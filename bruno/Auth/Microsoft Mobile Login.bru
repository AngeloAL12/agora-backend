meta {
  name: Microsoft Mobile Login
  type: http
  seq: 2
}

post {
  url: {{base_url}}/auth/microsoft/mobile-login
  body: json
  auth: inherit
}

body:json {
  {
    "token": "{{microsoft_id_token}}"
  }
}

script:post-response {
  if (res.getStatus() === 200) {
    const body = res.getBody();

    if (body.access_token) {
      bru.setEnvVar("auth_token", body.access_token);
    }

    if (body.refresh_token) {
      bru.setEnvVar("refresh_token", body.refresh_token);
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Inicio de Sesión Microsoft Mobile
  Procesa el inicio de sesión desde la aplicación móvil utilizando el SDK de Microsoft.

  ## Nota
  Este endpoint espera un `token` de Microsoft y devuelve `access_token` y `refresh_token`.
}
