meta {
  name: Get Auth Session
  type: http
  seq: 3
}

get {
  url: {{base_url}}/users/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Obtener Sesión Actual
  Recupera los detalles de la sesión y el perfil del usuario autenticado a través del Bearer Token.
}
