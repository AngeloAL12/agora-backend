meta {
  name: Google Mobile Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/google/mobile-login
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Inicio de Sesión Google Mobile
  Procesa el inicio de sesión desde la aplicación móvil utilizando el SDK de Google.
  
  ## Nota
  Este endpoint suele esperar el ID Token enviado desde el dispositivo móvil para validar la identidad con Google.
}
