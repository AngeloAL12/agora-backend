meta {
  name: Check Admin Access
  type: http
  seq: 3
}

get {
  url: {{base_url}}/users/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Verificar Acceso Admin
  Recupera el perfil del usuario actual y permite validar que el campo `role` sea `ADMIN`.
}
