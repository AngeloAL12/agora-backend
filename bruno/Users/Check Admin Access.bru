meta {
  name: Check Admin Access
  type: http
  seq: 3
}

get {
  url: {{base_url}}/users/admin
  body: none
  auth: bearer
}

auth:bearer {
  token: {{admin_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Verificar Acceso Admin
  Valida si el token de autenticación actual pertenece a un usuario con rol de Administrador.
}
