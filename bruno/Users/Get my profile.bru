meta {
  name: Get my profile
  type: http
  seq: 1
}

get {
  url: {{base_url}}/users/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Obtener Mi Perfil
  Recupera los detalles del perfil del usuario autenticado, como nombre, correo y carrera.
}
