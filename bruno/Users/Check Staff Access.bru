meta {
  name: Check Staff Access
  type: http
  seq: 4
}

get {
  url: {{base_url}}/users/staff
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Verificar Acceso Staff
  Valida si el token de autenticación actual pertenece a un usuario con rol de Staff o superior.
}
