meta {
  name: Edit my profile
  type: http
  seq: 5
}

patch {
  url: {{base_url}}/users/me
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

body:multipart-form {
  name: Angelo Alvarado
  id_career: 3
  ~photo: @file()
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Obtener Mi Perfil
  Recupera los detalles del perfil del usuario autenticado, como nombre, correo y carrera.
}
